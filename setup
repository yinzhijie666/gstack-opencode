#!/usr/bin/env bash
set -euo pipefail

GSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
BROWSE_BIN="$GSTACK_DIR/browse/dist/browse"

echo "gstack OpenCode setup"

ensure_playwright_browser() {
  (
    cd "$GSTACK_DIR"
    bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
  ) >/dev/null 2>&1
}

# 1. Install root dependencies when needed
if [ ! -d "$GSTACK_DIR/node_modules" ]; then
  echo "Installing root dependencies..."
  (cd "$GSTACK_DIR" && bun install)
fi

# 2. Install OpenCode-local dependencies when needed
if [ -f "$GSTACK_DIR/.opencode/package.json" ] && [ ! -d "$GSTACK_DIR/.opencode/node_modules" ]; then
  echo "Installing OpenCode dependencies..."
  (cd "$GSTACK_DIR/.opencode" && bun install)
fi

# 3. Build browse binary if needed (smart rebuild: stale sources, package.json, lock)
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$GSTACK_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$GSTACK_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$GSTACK_DIR/bun.lock" ] && [ "$GSTACK_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  echo "Building browse binary..."
  (
    cd "$GSTACK_DIR"
    bun install
    bun run build
  )
  # Safety net: write .version if build script didn't (e.g., git not available during build)
  if [ ! -f "$GSTACK_DIR/browse/dist/.version" ]; then
    git -C "$GSTACK_DIR" rev-parse HEAD > "$GSTACK_DIR/browse/dist/.version" 2>/dev/null || true
  fi
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "gstack setup failed: browse binary missing at $BROWSE_BIN" >&2
  exit 1
fi

# 4. Ensure Playwright's Chromium is available
if ! ensure_playwright_browser; then
  echo "Installing Playwright Chromium..."
  (
    cd "$GSTACK_DIR"
    bunx playwright install chromium
  )
fi

if ! ensure_playwright_browser; then
  echo "gstack setup failed: Playwright Chromium could not be launched" >&2
  exit 1
fi

# 5. Ensure ~/.gstack global state directory exists
mkdir -p "$HOME/.gstack/projects"

# 6. Finish
if [ ! -d "$HOME/.gstack" ]; then
  mkdir -p "$HOME/.gstack"
fi
rm -f /tmp/gstack-latest-version

echo "gstack ready for OpenCode."
echo "  browse: $BROWSE_BIN"
if [ -d "$GSTACK_DIR/.opencode" ]; then
  echo "  opencode assets: $GSTACK_DIR/.opencode"
fi
echo ""
echo "Next steps:"
echo "  1. Open this repo in OpenCode"
echo "  2. Use commands from README.md, for example /browse, /qa, or /review"
