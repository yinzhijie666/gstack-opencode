#!/bin/bash
DIR="$(cd "$(dirname "$0")/.." && pwd)/dist"
if test -x "$DIR/find-browse"; then
  exec "$DIR/find-browse" "$@"
fi
ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -n "$ROOT" ] && test -x "$ROOT/browse/dist/browse"; then
  echo "$ROOT/browse/dist/browse"
else
  echo "ERROR: browse binary not found. Run: ./setup or bun run build" >&2
  exit 1
fi
